{
  "name": "bet-bot-landing",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names client,server \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run build:server && npm run migration:run:prod && npm run start:server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.server.json && tsc-alias --project tsconfig.server.json",
    "preview": "vite preview",
    "start:server": "node dist/server/main.js",
    "start:server:prod": "npm run migration:run:prod && npm run start:server",
    "migration:run": "npm run build:server && npm run migration:run:prod",
    "migration:run:prod": "node node_modules/typeorm/cli.js -d dist/server/database/typeorm.datasource.js migration:run",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.server.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "aos": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "helmet": "^8.3.0",
    "lucide-react": "^1.25.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/react": "^16.3.2",
    "@types/aos": "^3.0.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.1",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
